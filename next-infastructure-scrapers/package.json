{
  "name": "next-infastructure-scrapers",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node server.js",
    "start:next": "next start",
    "start:prod": "NODE_ENV=production node server.js",
    "electron:dev": "electron .",
    "electron:start": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "pm2:start": "pm2 start server.js --name voxcode --update-env",
    "pm2:restart": "pm2 restart voxcode",
    "pm2:stop": "pm2 stop voxcode",
    "pm2:logs": "pm2 logs voxcode",
    "lint": "eslint"
  },
  "dependencies": {
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "@react-three/drei": "^9.121.4",
    "@react-three/fiber": "^9.0.0",
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9",
    "electron": "^35",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^8"
  }
}
