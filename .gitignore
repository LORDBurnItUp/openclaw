# ============================================================================
# OpenClaw Infrastructure - Git Ignore
# ============================================================================

# ----------------------------------------------------------------------------
# CRITICAL: Never commit these files
# ----------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
credentials.json
token.json
service-account*.json
secrets/
**/secrets/

# ----------------------------------------------------------------------------
# Temporary & Cache
# ----------------------------------------------------------------------------
.tmp/
.cache/
*.log
*.tmp
.DS_Store
Thumbs.db

# ----------------------------------------------------------------------------
# Python
# ----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
.mypy_cache/
.pytest_cache/
.ruff_cache/
venv/
.venv/
ENV/

# ----------------------------------------------------------------------------
# Node.js
# ----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.next/
.nuxt/
.output/
.vercel/
.netlify/

# ----------------------------------------------------------------------------
# IDE & Editor
# ----------------------------------------------------------------------------
.idea/
.vscode/settings.json
*.swp
*.swo
*~

# ----------------------------------------------------------------------------
# Database
# ----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
data/*.db

# ----------------------------------------------------------------------------
# Build outputs
# ----------------------------------------------------------------------------
out/
dist/
build/
*.min.js
*.min.css

# ----------------------------------------------------------------------------
# OS files
# ----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Next.js sub-project tracked separately via SSH deploy
# next-infastructure-scrapers/
voxcode/nul
next-infastructure-scrapers/nul
